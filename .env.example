# Copy to Railway service variables (never commit real values to git).
# Railway → your web service → Variables

# For local Docker / Railway web service — minimum required on WEB service:
MYSQLPASSWORD=your-mysql-password
Jwt__Key=change-me-to-a-long-random-secret-at-least-32-characters
ASPNETCORE_ENVIRONMENT=Production

# Optional overrides (defaults match Railway public proxy):
# RAILWAY_MYSQL_HOST=thomas.proxy.rlwy.net
# RAILWAY_MYSQL_PORT=30264
# RAILWAY_MYSQL_DATABASE=railway
# RAILWAY_MYSQL_USER=root

# Or full connection string instead of MYSQLPASSWORD:
# ConnectionStrings__Default=Server=HOST;Port=PORT;Database=railway;User=root;Password=PASSWORD;SslMode=Required;

# Required in production
Jwt__Key=change-me-to-a-long-random-secret-at-least-32-characters

# Optional — your Railway public URL (for CORS if frontend is hosted separately)
# Cors__Origins__0=https://your-app.up.railway.app

# Railway sets PORT automatically — do not override unless needed
