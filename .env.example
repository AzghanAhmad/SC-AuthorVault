# Copy to Railway service variables (never commit real values to git).
# Railway → your web service → Variables

# Option A — single connection string (recommended)
ConnectionStrings__Default=Server=YOUR_HOST;Port=YOUR_PORT;Database=railway;User=root;Password=YOUR_PASSWORD;SslMode=Required;

# Option B — Railway MySQL plugin injects these automatically when linked:
# MYSQLHOST=
# MYSQLPORT=
# MYSQLUSER=
# MYSQLPASSWORD=
# MYSQLDATABASE=

# Required in production
Jwt__Key=change-me-to-a-long-random-secret-at-least-32-characters

# Optional — your Railway public URL (for CORS if frontend is hosted separately)
# Cors__Origins__0=https://your-app.up.railway.app

# Railway sets PORT automatically — do not override unless needed
