{
  "name": "authorvault",
  "version": "1.0.0",
  "private": true,
  "description": "AuthorVault monorepo — local dev and Railway Docker deploy",
  "scripts": {
    "start": "npm run start:backend",
    "start:backend": "npm --prefix backend start",
    "start:frontend": "npm --prefix frontend start",
    "dev": "npm run dev:backend",
    "dev:backend": "npm --prefix backend run dev",
    "dev:frontend": "npm --prefix frontend start",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "npm --prefix frontend run build",
    "build:backend": "npm --prefix backend run build",
    "docker:build": "docker build -t authorvault .",
    "docker:run": "docker run --rm -p 8080:8080 --env-file .env authorvault"
  }
}
